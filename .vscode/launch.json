{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: uvicorn (real backends)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "coro.app:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--log-level",
        "debug"
      ],
      "jinja": true,
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env",
      "python": "${workspaceFolder}/.venv/bin/python"
    }
  ]
}